{
  "name": "node-koa-service",
  "version": "1.0.6",
  "description": "node.js + koa + typescript 构建服务端应用",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --require tsconfig-paths/register --respawn ./src/index.ts",
    "dev:test": "cross-env mode=test ts-node-dev --require tsconfig-paths/register --respawn ./src/index.ts",
    "dev:prod": "cross-env mode=prod ts-node-dev --require tsconfig-paths/register --respawn ./src/index.ts",
    
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc && tsc-alias && node dist/index.js",
    "build:test": "npm run clean && tsc && tsc-alias && cross-env mode=test node dist/index.js",
    "build:prod": "npm run clean && tsc && tsc-alias && cross-env mode=prod node dist/index.js",
    
    "build-sql": "ts-node-dev --respawn ./mysql/creator.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Travis-hjs/node-koa.git"
  },
  "keywords": [
    "koa",
    "nodejs"
  ],
  "author": "Travis-hjs",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Travis-hjs/node-koa/issues"
  },
  "homepage": "https://github.com/Travis-hjs/node-koa#readme",
  "dependencies": {
    "@koa/router": "15.4.0",
    "koa": "3.2.0",
    "koa-body": "7.0.1",
    "koa-static": "5.0.0",
    "mysql": "2.18.1"
  },
  "devDependencies": {
    "@types/koa": "3.0.2",
    "@types/koa-static": "4.0.4",
    "@types/mysql": "2.15.27",
    "@types/node": "25.6.0",
    "cross-env": "10.1.0",
    "ts-node-dev": "2.0.0",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.6.3"
  }
}
