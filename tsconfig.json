{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node"],
    // "strict": true,
    // "strictNullChecks": true,         // 严格的 null 和 undefined 检查
    "incremental": true,              // 启用增量编译
    "noImplicitAny": true,            // 禁止隐式的 any 类型
    "skipLibCheck": true,
    "noImplicitThis": true,           // 禁止隐式的 this类型
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": "./",
    "paths": {
      "*": [
        "node_modules/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "mysql",
    "public"
  ],
  "include": [
    "src/**/*.ts"
  ]
}